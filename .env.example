# Configuración de Seguridad para Nicoke Style Scheduler
# Copia este archivo a .env y completa con tus valores reales

# Usuario administrador para acceder al panel
VITE_ADMIN_USERNAME=ADMIN

# Contraseña del administrador (usa una contraseña fuerte y única)
VITE_ADMIN_PASSWORD=tu_contraseña_segura_aqui

# Clave secreta para encriptación de localStorage (genera una clave larga y aleatoria)
# Puedes generar una usando: openssl rand -base64 32
VITE_SECRET_KEY=tu_clave_secreta_aleatoria_y_larga_aqui

# NOTA IMPORTANTE:
# 1. Nunca compartas tu archivo .env real
# 2. Usa contraseñas fuertes y únicas
# 3. Cambia estos valores regularmente
# 4. El archivo .env está en .gitignore para proteger tus credenciales
